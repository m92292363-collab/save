  </div>

  <!-- JavaScript -->
  <script>
    (function() {
      'use strict';
      
      // Destination Carousel
      let destCurrentIndex = 0;
      const destSlides = document.querySelectorAll('#destinationCarousel .destination-carousel-slide');
      const destDots = document.querySelectorAll('#destinationDots .carousel-dot');
      const destContainer = document.getElementById('destinationCarousel');
      
      function updateDestinationCarousel() {
        if (!destContainer || !destSlides.length) return;
        
        destContainer.style.transform = `translateX(-${destCurrentIndex * 100}%)`;
        
        destDots.forEach((dot, index) => {
          if (index === destCurrentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      window.changeDestinationSlide = function(direction) {
        if (!destSlides.length) return;
        destCurrentIndex = (destCurrentIndex + direction + destSlides.length) % destSlides.length;
        updateDestinationCarousel();
      };

      window.currentDestinationSlide = function(index) {
        if (!destSlides.length) return;
        destCurrentIndex = Math.min(Math.max(index - 1, 0), destSlides.length - 1);
        updateDestinationCarousel();
      };

      // Hotel Carousel
      let hotelCurrentIndex = 0;
      const hotelSlides = document.querySelectorAll('#hotelCarousel .hotel-carousel-slide');
      const hotelDots = document.querySelectorAll('#hotelDots .carousel-dot');
      const hotelContainer = document.getElementById('hotelCarousel');

      function updateHotelCarousel() {
        if (!hotelContainer || !hotelSlides.length) return;
        
        hotelContainer.style.transform = `translateX(-${hotelCurrentIndex * 100}%)`;
        
        hotelDots.forEach((dot, index) => {
          if (index === hotelCurrentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      window.changeHotelSlide = function(direction) {
        if (!hotelSlides.length) return;
        hotelCurrentIndex = (hotelCurrentIndex + direction + hotelSlides.length) % hotelSlides.length;
        updateHotelCarousel();
      };

      window.currentHotelSlide = function(index) {
        if (!hotelSlides.length) return;
        hotelCurrentIndex = Math.min(Math.max(index - 1, 0), hotelSlides.length - 1);
        updateHotelCarousel();
      };

      // Initialize
      document.addEventListener('DOMContentLoaded', function() {
        updateDestinationCarousel();
        updateHotelCarousel();
        
        // Auto-advance carousels
        let destInterval = setInterval(() => {
          if (destSlides.length) {
            destCurrentIndex = (destCurrentIndex + 1) % destSlides.length;
            updateDestinationCarousel();
          }
        }, 5000);
        
        let hotelInterval = setInterval(() => {
          if (hotelSlides.length) {
            hotelCurrentIndex = (hotelCurrentIndex + 1) % hotelSlides.length;
            updateHotelCarousel();
          }
        }, 5000);

        // Pause auto-advance on user interaction
        const pauseAutoAdvance = () => {
          clearInterval(destInterval);
          clearInterval(hotelInterval);
        };

        document.querySelectorAll('.carousel-arrow, .carousel-dot').forEach(el => {
          el.addEventListener('click', pauseAutoAdvance);
        });
      });

      // Touch gesture support
      let touchStartX = 0;
      let touchEndX = 0;
      
      document.querySelector('.destination-carousel')?.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });
      
      document.querySelector('.destination-carousel')?.addEventListener('touchend', (e) => {
        touchEndX = e.changedTouches[0].screenX;
        handleSwipe('destination');
      }, { passive: true });
      
      document.querySelector('.hotel-carousel')?.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });
      
      document.querySelector('.hotel-carousel')?.addEventListener('touchend', (e) => {
        touchEndX = e.changedTouches[0].screenX;
        handleSwipe('hotel');
      }, { passive: true });
      
      function handleSwipe(type) {
        const swipeThreshold = 50;
        if (touchEndX < touchStartX - swipeThreshold) {
          if (type === 'destination') changeDestinationSlide(1);
          else changeHotelSlide(1);
        }
        if (touchEndX > touchStartX + swipeThreshold) {
          if (type === 'destination') changeDestinationSlide(-1);
          else changeHotelSlide(-1);
        }
      }
    })();
  </script>
</body>
</html>
