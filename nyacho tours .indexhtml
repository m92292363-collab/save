<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
  <title>Nyacho Tours · Gambia · explore your story</title>
  <!-- Font Awesome 6 (free) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    /* CSS Reset with improved cross-device support */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    :root {
      --primary-dark: #1e3d3a;
      --primary-teal: #2b6f6b;
      --primary-gold: #f3c26b;
      --text-dark: #1e2b2f;
      --text-soft: #2b4743;
      --text-light: #44615e;
      --bg-soft: #faf9f6;
      --bg-teal-soft: #dde9e6;
    }

    html {
      font-size: 16px;
      -webkit-text-size-adjust: 100%;
    }

    body {
      background-color: var(--bg-soft);
      color: var(--text-dark);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.5;
      overflow-x: hidden;
      width: 100%;
      position: relative;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 1rem;
      width: 100%;
    }

    /* Better touch targets for mobile */
    button, a, .carousel-arrow, .carousel-dot {
      touch-action: manipulation;
      cursor: pointer;
    }

    /* ===== NAVBAR ===== */
    .navbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 0;
      width: 100%;
      border-bottom: 1px solid rgba(43, 111, 107, 0.1);
      margin-bottom: 0.5rem;
      flex-wrap: wrap;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
    }

    .logo-icon {
      color: var(--primary-teal);
      font-size: 1.8rem;
    }

    .logo-text {
      font-size: 1.4rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--primary-dark);
      white-space: nowrap;
    }

    .logo-text span {
      color: var(--primary-teal);
      font-weight: 700;
    }

    /* Navigation Menu */
    .nav-menu {
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 1.8rem;
      list-style: none;
    }

    .nav-links li a {
      text-decoration: none;
      color: var(--text-dark);
      font-weight: 500;
      font-size: 1rem;
      padding: 0.5rem 0;
      position: relative;
      transition: color 0.2s;
    }

    /* Animated underline effect */
    .nav-links li a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--primary-gold);
      transition: width 0.3s ease;
    }

    .nav-links li a:hover {
      color: var(--primary-teal);
    }

    .nav-links li a:hover::after {
      width: 100%;
    }

    /* Active link style */
    .nav-links li a.active {
      color: var(--primary-dark);
      font-weight: 600;
    }

    .nav-links li a.active::after {
      width: 100%;
      background: var(--primary-teal);
    }

    /* Right icons */
    .nav-right {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      margin-left: 1rem;
    }

    .nav-right i {
      font-size: 1.3rem;
      color: var(--primary-teal);
      cursor: pointer;
      transition: all 0.2s;
      padding: 0.3rem;
      border-radius: 50%;
    }

    .nav-right i:hover {
      color: var(--primary-gold);
      transform: translateY(-2px);
    }

    /* Mobile styles */
    @media (max-width: 768px) {
      .nav-menu {
        gap: 1rem;
      }

      .nav-links {
        gap: 0.8rem;
      }

      .nav-links li a {
        font-size: 0.85rem;
      }

      .nav-right {
        gap: 0.6rem;
        margin-left: 0.5rem;
      }

      .nav-right i {
        font-size: 1.1rem;
      }
    }

    @media (max-width: 480px) {
      .logo-text {
        font-size: 1rem;
      }
      
      .logo-icon {
        font-size: 1.4rem;
      }
      
      .nav-links {
        gap: 0.5rem;
      }
      
      .nav-links li a {
        font-size: 0.75rem;
      }
      
      .nav-right {
        gap: 0.4rem;
      }
      
      .nav-right i {
        font-size: 1rem;
      }
    }

    @media (max-width: 360px) {
      .logo-text {
        font-size: 0.9rem;
      }
      
      .nav-links {
        gap: 0.3rem;
      }
      
      .nav-links li a {
        font-size: 0.7rem;
      }
    }

    /* ===== HERO SECTION ===== */
    .hero {
      background: linear-gradient(145deg, #e6f0ef 0%, #d6e9e6 80%);
      border-radius: 1.5rem;
      margin: 0.5rem 0 1.5rem 0;
      padding: 2rem 1.25rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      box-shadow: 0 25px 40px -20px rgba(0, 60, 50, 0.2);
      width: 100%;
      text-align: center;
    }

    .hero-content {
      flex: 1 1 100%;
      max-width: 800px;
      margin: 0 auto;
    }

    .hero-content h1 {
      font-size: clamp(1.8rem, 6vw, 3.2rem);
      line-height: 1.2;
      letter-spacing: -0.02em;
      color: #15312e;
      width: 100%;
    }

    .brand-highlight {
      color: var(--primary-dark);
      font-weight: 500;
      font-size: clamp(1.6rem, 5.5vw, 3rem);
      display: inline-block;
      letter-spacing: -0.02em;
    }

    .gold-strip {
      color: var(--primary-teal);
      border-bottom: 4px solid var(--primary-gold);
      display: inline-block;
      padding-bottom: 0.2rem;
      font-weight: 600;
      font-size: clamp(1.5rem, 5vw, 2.8rem);
    }

    .key-phrase {
      display: inline-block;
      font-size: clamp(1.4rem, 4.5vw, 2.4rem);
      font-weight: 400;
      color: var(--primary-dark);
      background: linear-gradient(145deg, #1e3d3a 0%, #2b6f6b 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      padding: 0.2rem 0;
      border-left: 4px solid var(--primary-gold);
      padding-left: 0.6rem;
      margin-top: 0.2rem;
      font-family: 'Georgia', 'Times New Roman', serif;
      font-style: italic;
      line-height: 1.3;
    }

    .hero-content p {
      font-size: clamp(0.95rem, 3.2vw, 1.2rem);
      margin: 1.2rem auto;
      color: var(--text-soft);
      line-height: 1.6;
      max-width: 600px;
      padding: 0 0.5rem;
    }

    .btn-group {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
      margin: 1rem 0 0.8rem;
    }

    .btn {
      padding: 0.7rem 1.5rem;
      border-radius: 40px;
      font-weight: 600;
      font-size: clamp(0.9rem, 3vw, 1rem);
      border: none;
      background: white;
      box-shadow: 0 10px 15px -8px rgba(0,0,0,0.1);
      transition: all 0.2s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--text-dark);
      -webkit-tap-highlight-color: transparent;
    }

    .btn:active {
      transform: scale(0.98);
    }

    .btn-primary {
      background: var(--primary-dark);
      color: white;
      box-shadow: 0 15px 20px -10px #1e3d3a80;
    }

    /* Book Now button */
    .book-now-btn {
      background: var(--primary-gold);
      color: var(--primary-dark);
      font-weight: 700;
      font-size: clamp(1rem, 3.5vw, 1.2rem);
      padding: 0.8rem 2rem;
      border-radius: 50px;
      text-decoration: none;
      box-shadow: 0 10px 20px -8px rgba(30, 61, 58, 0.3);
      transition: all 0.3s;
      border: 2px solid white;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      margin: 0.5rem auto 0;
      width: auto;
      max-width: 90%;
    }

    .book-now-btn i {
      font-size: 1.1rem;
    }

    .book-now-btn:active {
      transform: scale(0.96);
      background: #e6b15a;
    }

    /* Small phone adjustments for buttons */
    @media (max-width: 380px) {
      .btn {
        padding: 0.6rem 1.2rem;
        font-size: 0.9rem;
      }
      
      .book-now-btn {
        padding: 0.7rem 1.5rem;
        font-size: 0.95rem;
        width: 100%;
        justify-content: center;
      }
      
      .btn-group {
        flex-direction: column;
        width: 100%;
      }
      
      .btn {
        width: 100%;
        justify-content: center;
      }
    }

    /* ===== DESTINATIONS SECTION ===== */
    .destinations {
      background: white;
      border-radius: 1.5rem;
      padding: 1.5rem 1.25rem;
      margin: 2rem 0;
      box-shadow: 0 10px 30px -10px rgba(33, 55, 52, 0.1);
      width: 100%;
    }

    .destinations-header {
      margin-bottom: 1rem;
    }

    .destinations-header h2 {
      font-size: clamp(1.4rem, 4.5vw, 2rem);
      font-weight: 700;
      color: #15312e;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .destinations-header h2 i {
      color: var(--primary-gold);
    }

    /* ===== IMAGE CAROUSEL ===== */
    .destination-carousel {
      position: relative;
      width: 100%;
      overflow: hidden;
      border-radius: 1rem;
      margin-top: 0.5rem;
    }

    .destination-carousel-container {
      display: flex;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .destination-carousel-slide {
      min-width: 100%;
      flex-shrink: 0;
    }

    .destination-card {
      position: relative;
      width: 100%;
      background: #f0f0f0;
      border-radius: 1rem;
      overflow: hidden;
    }

    .image-container {
      position: relative;
      width: 100%;
      padding-bottom: 70%;
      background: #e0e0e0;
    }

    .destination-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-size: contain;
      background-position: center;
      background-repeat: no-repeat;
      background-color: #f5f5f5;
      transition: transform 0.3s ease;
    }

    @media (hover: hover) {
      .destination-card:hover .destination-image {
        transform: scale(1.02);
      }
    }

    /* ===== HOTELS SECTION ===== */
    .hotels {
      background: #dde9e6;
      border-radius: 1.5rem;
      padding: 1.5rem 1.25rem;
      margin: 2rem 0;
      width: 100%;
    }

    .hotels-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }

    .hotels-header h2 {
      font-size: clamp(1.4rem, 4.5vw, 2rem);
      font-weight: 700;
      color: #15312e;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .hotels-header h2 i {
      color: var(--primary-gold);
    }

    .hotel-badge {
      background: var(--primary-gold);
      color: var(--primary-dark);
      border-radius: 30px;
      padding: 0.3rem 0.8rem;
      font-size: clamp(0.7rem, 2.2vw, 0.85rem);
      font-weight: 600;
      white-space: nowrap;
    }

    .hotel-carousel {
      position: relative;
      width: 100%;
      overflow: hidden;
      border-radius: 1rem;
    }

    .hotel-carousel-container {
      display: flex;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .hotel-carousel-slide {
      min-width: 100%;
      flex-shrink: 0;
    }

    .hotel-card {
      position: relative;
      width: 100%;
      background: #f0f0f0;
      border-radius: 1rem;
      overflow: hidden;
    }

    .hotel-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-size: contain;
      background-position: center;
      background-repeat: no-repeat;
      background-color: #f5f5f5;
      transition: transform 0.3s ease;
    }

    @media (hover: hover) {
      .hotel-card:hover .hotel-image {
        transform: scale(1.02);
      }
    }

    /* ===== CAROUSEL NAVIGATION ===== */
    .carousel-nav {
      display: flex;
      justify-content: center;
      gap: 0.6rem;
      margin-top: 1rem;
      flex-wrap: wrap;
    }

    .carousel-dot {
      width: clamp(8px, 2vw, 10px);
      height: clamp(8px, 2vw, 10px);
      border-radius: 50%;
      background: #c0dbd5;
      transition: all 0.3s;
      -webkit-tap-highlight-color: transparent;
    }

    .carousel-dot.active {
      background: var(--primary-teal);
      transform: scale(1.3);
    }

    .carousel-arrows {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-top: 0.8rem;
    }

    .carousel-arrow {
      width: clamp(36px, 10vw, 42px);
      height: clamp(36px, 10vw, 42px);
      border-radius: 50%;
      background: white;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 5px 15px -5px #1a3f3b;
      transition: all 0.2s;
      -webkit-tap-highlight-color: transparent;
    }

    .carousel-arrow:active {
      background: var(--primary-gold);
      transform: scale(0.95);
    }

    .carousel-arrow i {
      color: var(--primary-dark);
      font-size: clamp(1rem, 3vw, 1.2rem);
    }

    /* ===== IMPROVED NEWSLETTER - FIXED MOBILE SIZING ===== */
    .newsletter {
      background: linear-gradient(135deg, #15312e 0%, #1e4a45 100%);
      border-radius: 1.5rem;
      padding: 2rem 1.5rem;
      color: white;
      margin: 2rem 0;
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      width: 100%;
    }

    .newsletter-left {
      flex: 1 1 300px;
    }

    .newsletter-left h3 {
      font-size: clamp(1.5rem, 5vw, 2rem);
      font-weight: 700;
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }

    .newsletter-left p {
      font-size: clamp(0.9rem, 3vw, 1.1rem);
      color: #bed9d4;
      line-height: 1.5;
    }

    .newsletter-form {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      background: white;
      border-radius: 60px;
      padding: 0.25rem;
      width: 100%;
      max-width: 500px;
    }

    .newsletter-form input {
      flex: 1 1 200px;
      border: none;
      padding: 0.7rem 1rem;
      font-size: 0.95rem;
      background: transparent;
      color: var(--text-dark);
      outline: none;
      min-width: 150px;
    }

    .newsletter-form button {
      background: var(--primary-gold);
      border: none;
      padding: 0.7rem 1.5rem;
      border-radius: 50px;
      font-weight: 700;
      color: #15312e;
      transition: 0.2s;
      white-space: nowrap;
      font-size: 0.95rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      -webkit-tap-highlight-color: transparent;
    }

    .newsletter-form button:active {
      background: #f0a84b;
      transform: scale(0.98);
    }

    /* Mobile optimization for newsletter - perfectly sized */
    @media (max-width: 600px) {
      .newsletter-form {
        flex-direction: row;
        background: white;
        border-radius: 60px;
        padding: 0.2rem;
        width: 100%;
      }
      
      .newsletter-form input {
        padding: 0.5rem 0.8rem;
        font-size: 0.85rem;
        flex: 1;
      }
      
      .newsletter-form button {
        padding: 0.5rem 1rem;
        font-size: 0.85rem;
        white-space: nowrap;
      }
    }

    @media (max-width: 480px) {
      .newsletter {
        padding: 1.5rem 1rem;
      }
      
      .newsletter-form {
        flex-direction: row;
        background: white;
        border-radius: 60px;
        padding: 0.15rem;
        width: 100%;
      }
      
      .newsletter-form input {
        padding: 0.5rem 0.7rem;
        font-size: 0.8rem;
        flex: 1;
      }
      
      .newsletter-form button {
        padding: 0.5rem 0.8rem;
        font-size: 0.8rem;
        white-space: nowrap;
      }
    }

    @media (max-width: 380px) {
      .newsletter-form input {
        padding: 0.45rem 0.6rem;
        font-size: 0.75rem;
      }
      
      .newsletter-form button {
        padding: 0.45rem 0.7rem;
        font-size: 0.75rem;
      }
    }

    /* ===== FOOTER ===== */
    .footer {
      border-top: 2px solid #d0dfdb;
      padding: 2rem 0 1rem;
      margin-top: 1.5rem;
      width: 100%;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .footer-col .logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.5rem;
      margin-bottom: 0.75rem;
    }

    .footer-col .logo i {
      color: var(--primary-teal);
    }

    .footer-col p {
      color: var(--text-light);
      line-height: 1.6;
      margin-bottom: 1rem;
      font-size: 0.9rem;
      max-width: 300px;
    }

    .footer-col h4 {
      font-size: 1.1rem;
      margin-bottom: 1rem;
      color: #15312e;
      font-weight: 700;
    }

    .footer-col ul {
      list-style: none;
    }

    .footer-col li {
      margin: 0.5rem 0;
    }

    .footer-col a {
      text-decoration: none;
      color: var(--text-light);
      transition: color 0.2s;
      font-size: 0.9rem;
      display: inline-block;
      padding: 0.2rem 0;
    }

    .footer-col a:active {
      color: var(--primary-teal);
    }

    .social {
      display: flex;
      gap: 1.2rem;
      margin-top: 0.75rem;
      flex-wrap: wrap;
    }

    .social a {
      text-decoration: none;
      display: inline-flex;
      transition: transform 0.2s;
      -webkit-tap-highlight-color: transparent;
    }

    .social a:active {
      transform: translateY(-2px);
    }

    .social .fa-instagram { color: #e4405f; }
    .social .fa-x-twitter { color: #000000; }
    .social .fa-tiktok { color: #000000; }
    .social .fa-facebook { color: #1877f2; }
    .social .fa-youtube { color: #ff0000; }
    .social .fa-whatsapp { color: #25d366; }

    .social i {
      font-size: 1.6rem;
    }

    .footer-bottom {
      border-top: 1px solid #d0dfdb;
      padding-top: 1.25rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      text-align: center;
    }

    .copyright {
      color: var(--text-light);
      font-size: 0.85rem;
    }

    .footer-links {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .footer-links a {
      color: var(--text-light);
      text-decoration: none;
      font-size: 0.85rem;
    }

    /* ===== ANIMATIONS ===== */
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    /* ===== FLOATING WHATSAPP ===== */
    .whatsapp-float {
      position: fixed;
      bottom: max(15px, env(safe-area-inset-bottom));
      right: max(15px, env(safe-area-inset-right));
      background-color: #25d366;
      color: white;
      width: clamp(50px, 12vw, 60px);
      height: clamp(50px, 12vw, 60px);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: clamp(2rem, 6vw, 2.5rem);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
      z-index: 100;
      transition: all 0.3s;
      text-decoration: none;
      -webkit-tap-highlight-color: transparent;
    }

    .whatsapp-float:active {
      background-color: #20b859;
      transform: scale(0.95);
    }

    /* iOS specific fixes */
    @supports (-webkit-touch-callout: none) {
      .destination-image, .hotel-image {
        background-attachment: scroll;
      }
      
      button, .btn, .carousel-arrow, .whatsapp-float {
        -webkit-appearance: none;
      }
    }
  </style>
</head>
<body>
  <!-- Floating WhatsApp Button -->
  <a href="https://wa.me/2207227561" class="whatsapp-float" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
    <i class="fab fa-whatsapp"></i>
  </a>

  <div class="container">
    <!-- Navbar -->
    <nav class="navbar">
      <a href="#" class="logo">
        <i class="fas fa-compass logo-icon"></i>
        <span class="logo-text">Nyacho <span>Tours</span> Gambia</span>
      </a>

      <div class="nav-menu">
        <ul class="nav-links">
          <li><a href="#" class="active">Home</a></li>
          <li><a href="#">Destinations</a></li>
          <li><a href="#">Packages</a></li>
          <li><a href="#">Stories</a></li>
          <li><a href="#">Contact</a></li>
        </ul>

        <div class="nav-right">
          <i class="fas fa-search"></i>
          <i class="fas fa-user-circle"></i>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
